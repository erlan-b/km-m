APP_NAME=Real Estate Marketplace API
APP_ENV=development
DEBUG=true
API_V1_PREFIX=/api/v1

JWT_SECRET_KEY=change-me-for-local-dev
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
SUPPORTED_LANGUAGES_CSV=en,ru
MEDIA_ROOT=storage
MESSAGE_ATTACHMENTS_SUBDIR=message_attachments
MESSAGE_ATTACHMENT_MAX_SIZE_MB=10
MESSAGE_ATTACHMENT_MAX_FILES_PER_MESSAGE=5
MESSAGE_ATTACHMENT_ALLOWED_MIME_CSV=image/jpeg,image/png,image/webp,application/pdf

DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=realestate_demo
DB_USER=root
DB_PASSWORD=root
