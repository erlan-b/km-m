APP_NAME=Real Estate Marketplace API
APP_ENV=development
DEBUG=true
API_V1_PREFIX=/api/v1

JWT_SECRET_KEY=change-me-for-local-dev
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=14
PASSWORD_RESET_TOKEN_EXPIRE_MINUTES=15
EXPOSE_PASSWORD_RESET_TOKEN=true
SUPPORTED_LANGUAGES_CSV=en,ru
MEDIA_ROOT=storage
MESSAGE_ATTACHMENTS_SUBDIR=message_attachments
MESSAGE_ATTACHMENT_MAX_SIZE_MB=10
MESSAGE_ATTACHMENT_MAX_FILES_PER_MESSAGE=5
MESSAGE_ATTACHMENT_ALLOWED_MIME_CSV=image/jpeg,image/png,image/webp,application/pdf
LISTING_MEDIA_SUBDIR=listing_media
LISTING_MEDIA_MAX_SIZE_MB=10
LISTING_MEDIA_MAX_FILES_PER_LISTING=20
LISTING_MEDIA_ALLOWED_MIME_CSV=image/jpeg,image/png,image/webp
CORS_ALLOWED_ORIGINS_CSV=http://localhost:3000,http://127.0.0.1:3000,http://localhost:5173,http://127.0.0.1:5173
CORS_ALLOWED_METHODS_CSV=GET,POST,PUT,PATCH,DELETE,OPTIONS
CORS_ALLOWED_HEADERS_CSV=*
CORS_ALLOW_CREDENTIALS=true
TRUSTED_HOSTS_CSV=localhost,127.0.0.1,testserver
GZIP_MINIMUM_SIZE=500
ENABLE_RATE_LIMIT=true
AUTH_RATE_LIMIT_REQUESTS=20
AUTH_RATE_LIMIT_WINDOW_SECONDS=60
SENSITIVE_RATE_LIMIT_REQUESTS=60
SENSITIVE_RATE_LIMIT_WINDOW_SECONDS=60

DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=realestate_demo
DB_USER=root
DB_PASSWORD=root
